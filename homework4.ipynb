n = int(input())
#seive
a = [True] * (n+1)
a[0] = a[1] = False
for i in range(2, int(n**0.5)+1):
    if a[i]:
        for j in range(i*i, n+1, i):
            a[j] = False
##print(a[17])
tmp = 0
Max = 0
id1,id2 = 0,0
for i in range(n+1):
    if a[i] == True:
        if Max < i - tmp:
            id1 = tmp
            id2 = i
            Max = i - tmp
        tmp = i
# print(Max,id1,id2)
ans = ''
for i in range(id1+1, id2):
    ans += str(i) + ' '
print(ans)
    


